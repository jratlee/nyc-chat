												<COLUMNFORMAT column-width="288" percentage="no"/>
												<COLUMNFORMAT column-width="144" percentage="no"/>
											</TABLEFORMAT>
											<ROW>
												<COL>
													<PARA>
														<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Citation</CHARFORMAT>
													</PARA>
												</COL>
												<COL>
													<PARA>
														<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Description of Non-Compliance</CHARFORMAT>
													</PARA>
												</COL>
												<COL>
													<PARA>
														<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Penalty</CHARFORMAT>
													</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>74 RCNY § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Jump" destination-name="T74C005_5-03" destination-id="0-0-0-19440">5-03</LINK>
													</PARA>
												</COL>
												<COL>
													<PARA>Failure to demonstrate best efforts to meet applicable Community Hiring Goal</PARA>
												</COL>
