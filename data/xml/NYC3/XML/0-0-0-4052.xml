									<PARA>
										<PICTURE id="0-0-0-58-img" object-class="Folio Objects" name="T01S-1101-01-Fig2" href="#!-- #EXECUTIVE:HOME_PATH --#/img/T01S-1101-01-Fig2" width="8640" height="14017" left-border-line-color="0" left-border-line-width="0" left-border-space="0" right-border-line-color="0" right-border-line-width="0" right-border-space="0" top-border-line-color="0" top-border-line-width="0" top-border-space="0" bottom-border-line-color="0" bottom-border-line-width="0" bottom-border-space="0"/>
