	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-148011" number="36597" version="2802">
			<HEADING>Chapter 63: Stationary Engines</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-19352" name="T15C063"/>Chapter 63: Stationary Engines</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-148018" number="36598" version="2802">
								<HEADING>§ 63-01 Definitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-19354" name="T15C063_63-01"/>§ 63-01 Definitions.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-148017" number="36599" version="2802">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Emergency Stationary Reciprocating Compression Ignition Combustion Engine</CHARFORMAT> means the same as set forth in 40 C.F.R. 63.6640(f). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-148016" number="36600" version="2802">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Selective Catalytic Reduction (SCR) Technology</CHARFORMAT> means a control device that creates a chemical reduction via a reducing agent and a catalyst. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-148015" number="36601" version="2802">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Stationary reciprocating compression ignition internal combustion engine (RICE)</CHARFORMAT> means the same as set forth in 40 C.F.R. 60.4219. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-148014" number="36602" version="2820">
									<PARA>(Added City Record 12/16/2024, eff. 1/15/2025) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-148019" number="36603" version="2802">
								<HEADING>§ 63-02 Requirements for Renewal of Certificate of Operation.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-19356" name="T15C063_63-02"/>§ 63-02 Requirements for Renewal of Certificate of Operation.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-148013" number="36604" version="2802">
									<PARA>A certificate of operation for a stationary reciprocating compression ignition combustion engine (RICE) that is required to obtain a certificate of operation pursuant to section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-122" destination-id="0-0-0-0">24-122</LINK> of the Air Pollution Control Code may be renewed on or after January 1, 2025, only if the RICE meets the Tier IV requirements set forth in 40 C.F.R. 60.4201, or any subsequent United States Environmental Protection Agency emissions standard for such engines that is at least as stringent. The certification standards are set forth in Table 1 of 40 C.F.R. 1039.101. Compliance with the Tier IV requirement may be demonstrated by submitting proof in a form satisfactory to the Department that SCR Technology has been installed. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-148012" number="36605" version="2875">
									<PARA>(Added City Record 12/16/2024, eff. 1/15/2025) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
