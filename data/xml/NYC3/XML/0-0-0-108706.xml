<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-108706" number="34313" version="979">
			<HEADING>Chapter 36: Cure Period for Certain Air and Noise Code Violations</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-15157" name="T15C036"/>Chapter 36: Cure Period for Certain Air and Noise Code Violations</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-108733" number="34314" version="979">
								<HEADING>§ 36-01 Definitions</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-15159" name="T15C036_36-01"/>§ 36-01 Definitions</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-108732" number="34315" version="979">
									<PARA>As used in this Chapter, the following terms are defined as follows: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108731" number="34316" version="979">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>&quot;Board&quot; means the New York City Environmental Control Board. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108730" number="34317" version="979">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>&quot;Code&quot; means the New York City Administrative Code. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108729" number="34318" version="979">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>&quot;Commissioner&quot; means the Commissioner of the Department of Environmental Protection. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108728" number="34319" version="979">
									<PARA>
										<TAB tab-count="1"/>(d)<TAB tab-count="1"/>&quot;Department&quot; means the New York City Department of Environmental Protection. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-108727" number="34320" version="2298">
								<HEADING>§ 36-02 Certification of Cure – Violation of § 24-165.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-15161" name="T15C036_36-02"/>§ 36-02 Certification of Cure – Violation of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-165" destination-id="0-0-0-0">24-165</LINK>.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-108726" number="34321" version="2298">
									<PARA>.<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Pursuant to subdivision g of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-165" destination-id="0-0-0-0">24-165</LINK> of the Code, the Commissioner may recommend to the Board that no civil penalty be imposed for a first violation of such section provided that, within 45 days after the return date, the respondent admits liability and files a certification with the Department containing the information and documentation prescribed in subdivision b of this section. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108725" number="34322" version="2512">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>The certification required by subdivision a of this section must be made by a licensed oil burner installer in a notarized letter to the Department that includes: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108724" number="34323" version="1816">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>A certification that the air contaminant recorder is functioning properly and is in compliance with § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-165" destination-id="0-0-0-0">24-165</LINK> of the Code; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108723" number="34324" version="979">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>A description of the work that was done to bring the device into compliance. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108722" number="34325" version="1816">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>If the Commissioner accepts the certification required by this section, he or she will recommend to the Board that no civil penalty be imposed for the violation. The violation may still serve as a predicate for purposes of imposing penalties for subsequent violations of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-165" destination-id="0-0-0-0">24-165</LINK> of the Code. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-108721" number="34326" version="2297">
								<HEADING>§ 36-03 Certification of Cure – Violation of § 24-166.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-15163" name="T15C036_36-03"/>§ 36-03 Certification of Cure – Violation of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-166" destination-id="0-0-0-0">24-166</LINK>.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-108720" number="34327" version="1816">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Pursuant to subdivision (c) of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-166" destination-id="0-0-0-0">24-166</LINK> of the Code, the Commissioner may recommend to the Board that no civil penalty be imposed for a first violation of such section provided that, within 45 days after the return date, the respondent admits liability and files a certification with the Department containing the information and documentation prescribed in subdivision b of this section. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108719" number="34328" version="979">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>The certification required by subdivision (a) of this section must be made by a licensed oil burner installer in a notarized letter to the Department that includes: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108718" number="34329" version="1816">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>A certification that the combustion shutoff is functioning properly and is in compliance with § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-166" destination-id="0-0-0-0">24-166</LINK> of the Code; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108717" number="34330" version="979">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>A description of the work that was done to bring the device into compliance. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108716" number="34331" version="1816">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>If the Commissioner accepts the certification required by this section, he or she will recommend to the Board that no civil penalty be imposed for the violation. The violation may still serve as a predicate for purposes of imposing penalties for subsequent violations of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-166" destination-id="0-0-0-0">24-166</LINK> of the Code. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-108715" number="34332" version="2297">
								<HEADING>§ 36-04 Certification of Cure – Violation of § 24-227.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-15165" name="T15C036_36-04"/>§ 36-04 Certification of Cure – Violation of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-227" destination-id="0-0-0-0">24-227</LINK>.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-108714" number="34333" version="1816">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Pursuant to paragraph (d) of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-227" destination-id="0-0-0-0">24-227</LINK> of the Code, the Commissioner may recommend to the Board that no civil penalty be imposed for a first violation of such section provided that, within 45 days after the return date, the respondent admits liability and files a certification with the Department containing the information and documentation prescribed in subdivision b of this section. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108713" number="34334" version="979">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>The certification required by subdivision (a) of this section must be made by a contractor or consultant retained by the owner of the circulation device in a notarized letter to the Department that includes: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108712" number="34335" version="1816">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>A certification that the circulation device is in compliance with the sound levels set forth in § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-227" destination-id="0-0-0-0">24-227</LINK> of the Code; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108711" number="34336" version="979">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>A description of all permanent improvements and modifications made to achieve compliance with such sound levels, including but not limited to, the installation of appropriate sound insulation, isolators, suspension mounting and/or sound mitigation devices or materials, and diagrams of such work, together with copies of all bills and receipts for such work; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108710" number="34337" version="979">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(3)<TAB tab-count="1"/>All sound level measurements taken at a location within the two closest receiving properties abutting the establishment and/or in a location specified by the Department. If there is difficulty gaining entry to any receiving property, the Department must be informed and will set an alternate location. All such measurements must be performed by a noise consultant or contractor. In the alternative, the respondent may request the Department to take measurements. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-108709" number="34338" version="2512">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>If the Commissioner determines that the work described in the certification required by this section is insufficient to correct the violation, the Commissioner may not recommend a zero penalty. If the Commissioner accepts the certification required by this section, he or she will recommend to the Board that no civil penalty be imposed for the violation. Such violation may still serve as a predicate for purposes of imposing penalties for subsequent violations of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-227" destination-id="0-0-0-0">24-227</LINK> of the Code. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-108708" number="34339" version="979">
								<HEADING>§ 36-05 Effect of Certification.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-15167" name="T15C036_36-05"/>§ 36-05 Effect of Certification.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-108707" number="34340" version="979">
									<PARA>Before the Commissioner recommends that no civil penalty be imposed for a first violation pursuant to 15 RCNY § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Jump" destination-name="T15C036_36-02" destination-id="0-0-0-15161">36-02</LINK>, <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Jump" destination-name="T15C036_36-03" destination-id="0-0-0-15163">36-03</LINK>, or <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Jump" destination-name="T15C036_36-04" destination-id="0-0-0-15165">36-04</LINK>, the Department may independently verify the documentation submitted by a respondent or the qualifications of the licensed oil burner installer, consultant, or contractor who performs the required corrective measures. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-029]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>