<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-56222" number="64274" version="1960">
			<HEADING>Chapter 16: Access to Boiler Rooms in Multiple Dwellings</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-7677" name="T28C016"/>Chapter 16: Access to Boiler Rooms in Multiple Dwellings</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-56223" number="64275" version="3">
								<HEADING>§ 16-01 Inspection Access.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-7679" name="T28C016_16-01"/>§ 16-01 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Inspection Access.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-56224" number="64276" version="3">
									<PARA>The owner of every multiple dwelling shall have the area, where the building&apos;s heating system is located, readily accessible to members of the department to make inspections pursuant to the Housing Maintenance Code. In the event such area is kept under lock, a key shall be kept on the premises at all times with such person as the owner shall designate; however, if there is a person residing on the premises who performs janitorial services, such person shall hold the key. The owner shall post two notices naming such designated person and his location.</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-56225" number="64277" version="3">
								<HEADING>§ 16-02 Notices.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-7681" name="T28C016_16-02"/>§ 16-02 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Notices.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-56226" number="64278" version="1163">
									<PARA>The notices in 28 RCNY § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Jump" destination-name="T28C016_16-01" destination-id="0-0-0-7679">16-01</LINK> above:</PARA>
								</RECORD>
								<RECORD id="0-0-0-56227" number="64279" version="2497">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>shall read: Key to heating system area lock is located at ________________________________________;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56228" number="64280" version="3">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>shall designate the apartment and person in possession of the key;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56229" number="64281" version="3">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>shall have letters not less than three-sixteenths of an inch in height;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56230" number="64282" version="3">
									<PARA>
										<TAB tab-count="1"/>(d)<TAB tab-count="1"/>shall be of sufficient size to accommodate the required lettering and to provide a margin of not less than one-fourth inch about the lettering on all sides;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56231" number="64283" version="3">
									<PARA>
										<TAB tab-count="1"/>(e)<TAB tab-count="1"/>the letters and the background of the notice shall be of contrasting colors;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56232" number="64284" version="3">
									<PARA>
										<TAB tab-count="1"/>(f)<TAB tab-count="1"/>shall be of metal, plastic or decal;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56233" number="64285" version="3">
									<PARA>
										<TAB tab-count="1"/>(g)<TAB tab-count="1"/>shall be placed preferably over the mailboxes but, in any case, shall be conspicuously displayed in a prominent location in the entrance hall; a second notice shall be placed on the entrance door of the locked area where the building&apos;s heating system is located;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56234" number="64286" version="3">
									<PARA>
										<TAB tab-count="1"/>(h)<TAB tab-count="1"/>shall be between 6 feet and 8 feet above the floor;</PARA>
								</RECORD>
								<RECORD id="0-0-0-56235" number="64287" version="3">
									<PARA>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>shall be maintained free of damage or defacement.</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>