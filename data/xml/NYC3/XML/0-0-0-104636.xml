							<RECORD id="0-0-0-104638" number="36157" version="766">
								<HEADING>§ 50-01 Engines in Mobile Food Vending Units.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-14836" name="T15C050_50-01"/>§ 50-01 Engines in Mobile Food Vending Units.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-104639" number="36158" version="2297">
									<PARA>No person shall cause or permit the installation, use, or operation of any engine in a mobile food vending unit with an input of less than 50 horsepower unless he or she has first registered the engine with the Department in accordance with the requirements of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="24-109" destination-id="0-0-0-0">24-109</LINK> of the Administrative Code. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-022]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-104637" number="36159" version="766">
									<PARA>(Added City Record 1/16/2018, eff. 2/15/2018) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-022]</HIGHLIGHTER>
									</PARA>
