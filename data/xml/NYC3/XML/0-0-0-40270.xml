<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-40270" number="47269" version="3">
			<HEADING>Chapter 32: Claims Against Fire Insurance Proceeds</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-5489" name="T19C032"/>Chapter 32: Claims Against Fire Insurance Proceeds</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-40271" number="47270" version="3">
								<HEADING>§ 32-01 Submission Requirements.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-5491" name="T19C032_32-01"/>§ 32-01 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Submission Requirements.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-40272" number="47271" version="3">
									<PARA>The notice of claim and demand for certificate of lien required to be submitted to the Commissioner of Finance under the provisions of § 28-01(3) of the Administrative Code of New York City and Section 331 of the New York State Insurance Law, shall be submitted in person or by registered or certified mail to: </PARA>
								</RECORD>
								<RECORD id="0-0-0-40273" number="47272" version="3">
									<PARA>
										<TAB tab-count="1"/>Department of Finance, Tax Operations Division <LINEBRK/>
										<TAB tab-count="1"/>Attention: Special Programs Unit Manager <LINEBRK/>
										<TAB tab-count="1"/>Fire Insurance Proceeds Section <LINEBRK/>
										<TAB tab-count="1"/>25 Elm Place, 4th Floor <LINEBRK/>
										<TAB tab-count="1"/>Brooklyn, New York 11201 </PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-40274" number="47273" version="3">
								<HEADING>§ 32-02 Twenty Day Period for Filing Lien.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-5493" name="T19C032_32-02"/>§ 32-02 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Twenty Day Period for Filing Lien.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-40275" number="47274" version="3">
									<PARA>The 20 day period provided in Section 331(d) of the New York State Insurance Law, in which the Department of Finance must file its Certificate of Special Lien, shall run from the date of receipt of the insurer&apos;s notice of claim and demand for certificate of lien at the address specified herein. When such notice and demand is submitted by mail, it shall be deemed to have been received by the office specified herein on the date of receipt indicated in the United States Post Office certificate of mailing.</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>