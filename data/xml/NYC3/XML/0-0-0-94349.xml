								<RECORD id="0-0-0-114999" number="112653" version="1466">
									<PARA>One would determine the total number of funded meals for a provider serving 6,000 meals per year as follows:<LINEBRK/>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-115004" number="112654" version="2497">
									<PARA>
										<TABLE>
											<TABLEFORMAT number-of-widths="2" horizontal-alignment="0">
												<COLUMNFORMAT column-width="10" percentage="yes"/>
												<COLUMNFORMAT column-width="9" percentage="yes"/>
											</TABLEFORMAT>
											<ROW>
												<COL>
													<PARA>
														<PARAFORMAT justify="right">2,799 × 8 =</PARAFORMAT>
													</PARA>
												</COL>
												<COL>
													<PARA>22,392</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>
														<PARAFORMAT justify="right">(4,999 - 2,800) × 4 =</PARAFORMAT>
													</PARA>
												</COL>
												<COL>
													<PARA>
														<PARAFORMAT tab-count="1">
															<TABSTOP number="0" position="7" justification="left" leader="none"/>
															<TAB tab-count="1"/>8,796</PARAFORMAT>
													</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>
														<PARAFORMAT justify="right">(6,000 - 5,000) × 2 =</PARAFORMAT>
													</PARA>
												</COL>
												<COL>
													<PARA>
														<PARAFORMAT tab-count="1">
															<TABSTOP number="0" position="7" justification="left" leader="none"/>
															<TAB tab-count="1"/>2,000</PARAFORMAT>
													</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>
													</PARA>
												</COL>
												<COL>
													<PARA>33,188 funded meals</PARA>
												</COL>
											</ROW>
										</TABLE>
									</PARA>
									<PARA>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-115005" number="112655" version="1466">
									<PARA>The total number of funded meals is then multiplied by the dollar value of each funded meal to determine a provider&apos;s meal budget.</PARA>
								</RECORD>
