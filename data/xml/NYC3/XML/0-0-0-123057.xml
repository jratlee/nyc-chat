<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-123057" number="101687" version="1696">
			<HEADING>Chapter 17: Public Access to Information*</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-16413" name="T52C017"/>Chapter 17: Public Access to Information*</PARA>
		</RECORD>
		<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
			<RECORD id="0-0-0-123058" number="101688" version="2478">
				<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-20">
					<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">* Editor&apos;s note:</CHARFORMAT> Former Chapter 16, Runoff Elections, was repealed and this chapter was renumbered from Chapter 18. See City Record 5/22/2020, eff. 6/21/2020. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
				</PARA>
			</RECORD>
		</LEVEL>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-126411" number="101689" version="1696">
								<HEADING>§ 17-01 Records Available to the Public.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16679" name="T52C017_17-01"/>§ 17-01 Records Available to the Public.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123059" number="101690" version="2305">
									<PARA>The New York State Freedom of Information Law (FOIL) (Public Officers Law, Article 6, §§ 84 et seq.) governs public access to the Board&apos;s records. The Board may deny access to records or portions of records that are exempted from disclosure by state or federal law. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123060" number="101691" version="1696">
									<PARA>(Added City Record 8/16/2019, eff. 9/15/2019; amended City Record 5/22/2020, eff. 6/21/2020) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-123061" number="101692" version="1696">
								<HEADING>§ 17-02 Records Access Officer.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16683" name="T52C017_17-02"/>§ 17-02 Records Access Officer.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123062" number="101693" version="1698">
									<PARA>The Board&apos;s records access officer is designated by the Executive Director and is responsible for ensuring appropriate agency response to public requests for access to records. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123063" number="101694" version="1696">
									<PARA>(Added City Record 8/16/2019, eff. 9/15/2019; amended City Record 5/22/2020, eff. 6/21/2020) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-123064" number="101695" version="1696">
								<HEADING>§ 17-03 Requesting Records.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16685" name="T52C017_17-03"/>§ 17-03 Requesting Records.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123088" number="101696" version="1698">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>A candidate may request access to records such candidate submitted to the Board by contacting the Candidate Guidance and Policy Unit, which may provide access to such records without a FOIL request. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126505" number="101697" version="1698">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>To request access to Board records, a member of the public must: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126504" number="101698" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>make a written FOIL request in person, by mail, or by email, addressed to the Board&apos;s records access officer; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126503" number="101699" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>reasonably describe the records sought; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126502" number="101700" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iii)<TAB tab-count="1"/>provide the requestor&apos;s name and mailing or email address; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126501" number="101701" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iv)<TAB tab-count="1"/>specify preference for inspection of records or copies of records. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126500" number="101702" version="1698">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>Within five business days of receipt of a FOIL request made in accordance with subdivision (b) above, the Board will: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126499" number="101703" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>grant or deny the request, in whole or in part, in writing; or <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126498" number="101704" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>provide: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126497" number="101705" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(A)<TAB tab-count="1"/>a written acknowledgment of the request and state the approximate date on which the request will be granted or denied; or <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126496" number="101706" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(B)<TAB tab-count="1"/>where circumstances prevent granting or denying the request within 20 business days of the written acknowledgment, <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126495" number="101707" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>a written statement of the reasons for the delay in making a determination; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126494" number="101708" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>a date, within a reasonable period depending on the circumstances, when the request will be granted or denied. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126493" number="101709" version="1698">
									<PARA>
										<TAB tab-count="1"/>(d)<TAB tab-count="1"/>Where the Board is unable to locate records responsive to the request, the Board, upon request, will certify that: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126492" number="101710" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>the Board is not the custodian of such records; or <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126491" number="101711" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>such records cannot be found after a diligent search. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126490" number="101712" version="1698">
									<PARA>
										<TAB tab-count="1"/>(e)<TAB tab-count="1"/>Where the request is granted, the Board will: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126489" number="101713" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>make records available for inspection: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126488" number="101714" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(A)<TAB tab-count="1"/>between the hours of 10:00 a.m. and 4:00 p.m., on business days, Monday through Friday; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126487" number="101715" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(B)<TAB tab-count="1"/>at the offices of the Board or another location chosen by the Board; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126486" number="101716" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(C)<TAB tab-count="1"/>in quantities that may be limited to the amount available at the time; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126485" number="101717" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(D)<TAB tab-count="1"/>contingent on the requester&apos;s promise that the records will not be removed, damaged, marked, or changed in any way during the inspection; or <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126484" number="101718" version="1698">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>make copies of records available in the medium requested, where practicable, upon payment of fees as described in this Chapter, and provide, on request, a certification that the copies are true copies; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126483" number="101719" version="1698">
									<PARA>
										<TAB tab-count="1"/>(f)<TAB tab-count="1"/>Where a request is denied, the Board will explain the reasons for the denial in writing and set forth the right to appeal. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123089" number="101720" version="1698">
									<PARA>(Added City Record 8/16/2019, eff. 9/15/2019; amended City Record 5/22/2020, eff. 6/21/2020) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-123090" number="101721" version="1696">
								<HEADING>§ 17-04 Appealing a Denial of Access to Records.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16687" name="T52C017_17-04"/>§ 17-04 Appealing a Denial of Access to Records.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123097" number="101722" version="1699">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>To appeal a denial of access to records, the requester must, within 30 days of the denial, submit a written appeal to the Board&apos;s General Counsel including: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126512" number="101723" version="1699">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>a copy of the original request; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126511" number="101724" version="1699">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>a reasonable description of the records to which access was denied; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126510" number="101725" version="1699">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iii)<TAB tab-count="1"/>the name and address of the requester. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126509" number="101726" version="1699">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>Upon receipt of an appeal, the Board&apos;s General Counsel shall, within 10 business days: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126508" number="101727" version="1699">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>decide the appeal and send a copy of the written decision to the requester; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-126507" number="101728" version="1699">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>send a copy of the appeal and a copy of the written decision to the Committee on Open Government of the Department of State of the State of New York. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-050]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123098" number="101729" version="1699">
