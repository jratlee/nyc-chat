<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-126762" number="102306" version="1711">
			<HEADING>Chapter 5: Legal Defense Trusts</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-16693" name="T53C005"/>Chapter 5: Legal Defense Trusts</PARA>
		</RECORD>
		<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
			<RECORD id="0-0-0-123222" number="102307" version="1586">
				<PARA>
					<PARAFORMAT justify="center">(Chapter added City Record 8/28/2019, eff. 9/27/2019) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
					</PARAFORMAT>
				</PARA>
			</RECORD>
		</LEVEL>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-123223" number="102308" version="1586">
								<HEADING>§ 5-01 Definitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16695" name="T53C005_5-01"/>§ 5-01 Definitions.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123267" number="102309" version="1586">
									<PARA>&quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">In-kind donation</CHARFORMAT>&quot; means any donation of any value, other than money, such as the use of space, materials, supplies, or perishables. The donation value of an in-kind donation will be established by a reasonable estimate of that portion of its fair market value that is not paid or reimbursed by the trust. Personal expenses paid by the trustee(s) or volunteer clerical staff for the purpose of administering the trust are not in-kind donations. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123266" number="102310" version="1586">
									<PARA>&quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Pro bono assistance</CHARFORMAT>&quot; means the provision of professional services, including but not limited to legal, accounting, and fundraising services. The donation value of pro bono assistance will be established by a reasonable estimate of that portion of its fair market value that is not paid or reimbursed by the trust. Pro bono assistance does not include uncompensated work by the trustee(s) for the purpose of administering the trust or volunteer clerical assistance. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123265" number="102311" version="1586">
									<PARA>(Added City Record 8/28/2019, eff. 9/27/2019) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-123272" number="102312" version="1586">
								<HEADING>§ 5-02 Donations.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16697" name="T53C005_5-02"/>§ 5-02 Donations.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123264" number="102313" version="1586">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Multiple donations made by a person shall be aggregated for the purposes of the: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123263" number="102314" version="1888">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>$5,000 donation limit established in Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-1102" destination-id="0-0-0-0">3-1102</LINK>(e)(1); and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123262" number="102315" version="1888">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>$100 reporting threshold established in Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-1103" destination-id="0-0-0-0">3-1103</LINK>(a)(1). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123261" number="102316" version="1586">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>A legal defense trust may not accept cash totaling $100 or more from a single donor. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123260" number="102317" version="1888">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>A legal defense trust may not accept a donation without having received the signed disclosure document from the donor as required by Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-1102" destination-id="0-0-0-0">3-1102</LINK>(e)(3). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123259" number="102318" version="1888">
									<PARA>
										<TAB tab-count="1"/>(d)<TAB tab-count="1"/>In-kind donations and pro bono assistance may only be accepted for the purposes of administering the trust, pursuant to Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-1102" destination-id="0-0-0-0">3-1102</LINK>(f)(1)(b). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123258" number="102319" version="1586">
									<PARA>(Added City Record 8/28/2019, eff. 9/27/2019) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-123271" number="102320" version="1586">
								<HEADING>§ 5-03 Reporting and Disclosure.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16699" name="T53C005_5-03"/>§ 5-03 Reporting and Disclosure.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123257" number="102321" version="1888">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>In addition to the information required by Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-1103" destination-id="0-0-0-0">3-1103</LINK>(a)(1) regarding the reporting of donations, the trustee(s) must: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123256" number="102322" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>Disclose <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123255" number="102323" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>the description and use of any in-kind donation and any pro bono assistance accepted; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123254" number="102324" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>the date and amount of any refund to a donor. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123253" number="102325" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>Submit the following documents: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123252" number="102326" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>a copy of the receipt, check, or other document establishing that the donation was made by the donor; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123251" number="102327" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>a copy of the receipt, check, or other document establishing that a refund, if any, was made by the legal defense trust; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123250" number="102328" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iii)<TAB tab-count="1"/>a copy of the receipt or other written record establishing the value of in-kind donations or pro bono assistance; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123249" number="102329" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iv)<TAB tab-count="1"/>a copy of the donor&apos;s signed disclosure document. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123248" number="102330" version="1888">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>In addition to the information required by Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-1103" destination-id="0-0-0-0">3-1103</LINK>(a)(2) regarding the reporting of expenditures, the trustee(s) must: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123247" number="102331" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>Disclose <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123246" number="102332" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>the date the expense was incurred; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123245" number="102333" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>the date the expense was paid; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123244" number="102334" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iii)<TAB tab-count="1"/>the amount, if any, returned to the trust, pursuant to Administrative Code § 3-1102(f)(4). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123243" number="102335" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>Submit the following documents: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123242" number="102336" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>a copy of the itemized receipt for each expense; and <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123241" number="102337" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>a copy of the check or other document establishing that the expenditure was paid by the legal defense trust. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123240" number="102338" version="1586">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>Quarterly reports submitted by the legal defense trust must include all bank, credit card, and merchant account statements received by the trust during the reporting period. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123239" number="102339" version="1586">
									<PARA>(Added City Record 8/28/2019, eff. 9/27/2019) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-123270" number="102340" version="1586">
								<HEADING>§ 5-04 Dissolution.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16701" name="T53C005_5-04"/>§ 5-04 Dissolution.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-123238" number="102341" version="1888">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>If the trustee(s) returns donations on dissolution of a legal defense trust, the trustee(s) must submit in the last disclosure report, pursuant to Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-1103" destination-id="0-0-0-0">3-1103</LINK>: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123237" number="102342" version="1586">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>the name and address of each donor receiving a refund; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-123236" number="102343" version="1586">
									<PARA>
										<TAB tab-count="1"/>
