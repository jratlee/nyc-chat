									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(x)<TAB tab-count="1"/>Judgment;</PARA>
								</RECORD>
								<RECORD id="0-0-0-41213" number="48825" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(xi)<TAB tab-count="1"/>Life estate deed;</PARA>
								</RECORD>
								<RECORD id="0-0-0-41214" number="48826" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(xii)<TAB tab-count="1"/>Memorandum of contract;</PARA>
								</RECORD>
								<RECORD id="0-0-0-41215" number="48827" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(xiii)<TAB tab-count="1"/>Power of attorney;</PARA>
								</RECORD>
