									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(xiv)<TAB tab-count="1"/>Real estate investment trust deed;</PARA>
								</RECORD>
								<RECORD id="0-0-0-41217" number="48829" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
