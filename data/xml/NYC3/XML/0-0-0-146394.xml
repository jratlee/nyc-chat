								</RECORD>
								<RECORD id="0-0-0-41218" number="48830" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(xvi)<TAB tab-count="1"/>Sundry agreement; and</PARA>
								</RECORD>
								<RECORD id="0-0-0-41219" number="48831" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(xvii)<TAB tab-count="1"/>Unit assignment.</PARA>
								</RECORD>
								<RECORD id="0-0-0-41220" number="48832" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Mortgage-related documents.</CHARFORMAT> For purposes of this section, a mortgage-related document shall include any document determined by the City Register to be mortgage-related, and includes, but is not limited to:</PARA>
								</RECORD>
								<RECORD id="0-0-0-41221" number="48833" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
