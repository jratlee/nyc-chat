							<RECORD id="0-0-0-43239" number="52042" version="1942">
								<HEADING>§ 13-01 Scope and Applicability.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-6023" name="T24C013_13-01"/>§ 13-01 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Scope and Applicability.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-43240" number="52043" version="1854">
									<PARA>This chapter applies to sales of cigarettes and tobacco products in the City of New York pursuant to § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="17-176.1" destination-id="0-0-0-0">17-176.1</LINK> and <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="T17C007" destination-id="0-0-0-0">Chapter 7 of Title 17</LINK> of the Administrative Code of the City of New York (&quot;Administrative Code&quot;).</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-43241" number="52044" version="1180">
								<HEADING>§ 13-02 Definitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-6025" name="T24C013_13-02"/>§ 13-02 Definitions<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-43247" number="52045" version="2502">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>&quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Cigar</CHARFORMAT>,&quot; &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">little cigar</CHARFORMAT>,&quot; &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">loose tobacco</CHARFORMAT>,&quot; &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">non-tobacco shisha</CHARFORMAT>,&quot; &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">shisha</CHARFORMAT>,&quot; &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">smokeless tobacco</CHARFORMAT>,&quot; &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">snus</CHARFORMAT>,&quot; and &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">tobacco product</CHARFORMAT>&quot; are defined in the same manner as those terms are defined in § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="17-176.1" destination-id="0-0-0-0">17-176.1</LINK> of the Administrative Code. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-030]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-109854" number="52046" version="2502">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>&quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Price floor</CHARFORMAT>&quot; means the price floor described in subdivision (d) of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="17-176.1" destination-id="0-0-0-0">17-176.1</LINK> of the Administrative Code. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-030]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-109852" number="52047" version="1180">
									<PARA>(Amended City Record 9/11/2018, eff. 10/11/2018) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-030]</HIGHLIGHTER>
									</PARA>
