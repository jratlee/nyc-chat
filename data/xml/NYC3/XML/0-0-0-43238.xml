								<HEADING>§ 13-05 Sale of Cigarettes, Tobacco Products, or Electronic Cigarettes to Minors and Young Adults Prohibited. [Repealed]</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-6031" name="T24C013_13-05"/>§ 13-05 Sale of Cigarettes, Tobacco Products, or Electronic Cigarettes to Minors and Young Adults Prohibited<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">. [Repealed]</CHARFORMAT>
								</PARA>
							</RECORD>
