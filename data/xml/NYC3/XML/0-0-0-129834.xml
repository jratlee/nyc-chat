<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-129834" number="111806" version="2495">
			<HEADING>Chapter 17: NYC Small Business COVID Recovery Grant Program</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-17210" name="T66C017"/>Chapter 17: NYC Small Business COVID Recovery Grant Program</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-129836" number="111807" version="2048">
								<HEADING>§ 17-01 Purpose.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17212" name="T66C017_17-01"/>§ 17-01 Purpose.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-129869" number="111808" version="2502">
									<PARA>The objective of the NYC Small Business COVID Recovery Grant Program (&quot;Grant Program&quot;) is to provide immediate funding to small businesses in LMI areas, and small businesses in the Arts, Entertainment, and Recreation sector and small businesses in the Accommodation and Food Services sector. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129868" number="111809" version="2048">
									<PARA>(Added City Record 9/17/2021, eff. 9/17/2021) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-129874" number="111810" version="2048">
								<HEADING>§ 17-02 Definitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17214" name="T66C017_17-02"/>§ 17-02 Definitions.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-129867" number="111811" version="2048">
									<PARA>As used in this chapter, the following terms have the following meanings: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129866" number="111812" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Applicant.</CHARFORMAT> &quot;Applicant&quot; means a commercial business that is applying for this grant. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129865" number="111813" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Application.</CHARFORMAT> &quot;Application&quot; means a written request in a form satisfactory to DSBS, supplemented by all requested supporting documents, made by an applicant to DSBS to determine the eligibility of an applicant for a grant. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129863" number="111814" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Business.</CHARFORMAT> &quot;Business&quot; means a sole proprietorship, partnership, corporation, or other legal entity involved in the sale of goods or services directly to the public from a physical location in the City. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129862" number="111815" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">City.</CHARFORMAT> &quot;City&quot; means the City of New York. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129875" number="111816" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">DSBS.</CHARFORMAT> &quot;DSBS&quot; means the Department of Small Business Services or its successor. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129876" number="111817" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Grant.</CHARFORMAT> &quot;Grant&quot; means one or more disbursements from the NYC Small Business COVID Recovery Grant Program to an applicant. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129877" number="111818" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">LMI Small Business.</CHARFORMAT> &quot;LMI small business&quot; means a small business that physically operates from a census tract determined to be low-to-moderate income by the United States Department of Housing and Urban Development (HUD). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129859" number="111819" version="2502">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Small Business.</CHARFORMAT> &quot;Small business&quot; means a business concern or other organization that: (1) Has no more than 500 employees, or if applicable, the size standard in number of employees established by the federal Administrator of the Small Business Administration for the industry in which the business concern or organization operates, and (2) Is a small business concern as defined in section 3 of the Small Business Act (15 U.S.C. § 632). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129858" number="111820" version="2048">
									<PARA>(Added City Record 9/17/2021, eff. 9/17/2021) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-129873" number="111821" version="2048">
								<HEADING>§ 17-03 Eligibility Requirements.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17216" name="T66C017_17-03"/>§ 17-03 Eligibility Requirements.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-129857" number="111822" version="2048">
									<PARA>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Eligible Recipients.</CHARFORMAT> To be eligible for a grant, an applicant must satisfy all of the following criteria: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129856" number="111823" version="2049">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Applicant must operate a small business in which at least 50% of its revenue is generated from activities that are defined by the North American Industry Classification System (NAICS) as part of the Accommodation and Food Services sector, or the Arts, Entertainment, and Recreation sector; or operate an LMI small business. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129855" number="111824" version="2049">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>Applicant must be in operation at the time of submission of the application. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129854" number="111825" version="2049">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>Applicant must demonstrate annual revenue or gross receipts. Documentation may include, but need not be limited to: signed Federal or State tax return(s); State sales tax returns. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129853" number="111826" version="2049">
									<PARA>
										<TAB tab-count="1"/>(d)<TAB tab-count="1"/>Applicant must demonstrate at least a 25% reduction in gross receipts or revenue in either: (1) comparable quarters in 2019 and 2020; or (2) the 12-month calendar year 2019 and the 12-month calendar year 2020. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129852" number="111827" version="2049">
									<PARA>
										<TAB tab-count="1"/>(e)<TAB tab-count="1"/>Applicant must be in substantial compliance with applicable Federal, State, and local laws, rules and other legal requirements. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129851" number="111828" version="2049">
									<PARA>
										<TAB tab-count="1"/>(f)<TAB tab-count="1"/>Applicant must be current or in repayment on all Federal, State or City taxes (including delinquency repayment, prior to December 31, 2019). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129850" number="111829" version="2049">
									<PARA>
										<TAB tab-count="1"/>(g)<TAB tab-count="1"/>Applicant must not have received a grant from any of the following programs: (1) Shuttered Venues Operators Grant Program, or (2) Restaurant Revitalization Fund. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129849" number="111830" version="2049">
									<PARA>
										<TAB tab-count="1"/>(h)<TAB tab-count="1"/>Applicants must follow any additional, detailed application requirements outlined in the application which will be made available online at <LINK style-name="Web" style-name-escaped="Web" style-id="0-0-0-32" type="Web" url="www.nyc.gov/sbs">www.nyc.gov/sbs</LINK> or by directly contacting DSBS. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129848" number="111831" version="2497">
									<PARA>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>Applicant must use the grant to mitigate economic hardships that occurred as a result of the COVID-19 pandemic by using the grant funds to offset operational expenses for the small business that is the basis for the applicant&apos;s eligibility for the grant. Examples of appropriate uses for a grant include the following costs: payroll and benefits, mortgage, rent, utilities, and other operating costs. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129847" number="111832" version="2048">
									<PARA>(Added City Record 9/17/2021, eff. 9/17/2021) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-129872" number="111833" version="2048">
								<HEADING>§ 17-04 Selection Criteria.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17218" name="T66C017_17-04"/>§ 17-04 Selection Criteria.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-129846" number="111834" version="2049">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>DSBS will use the following processes &amp; documents to determine whether a business meets the eligibility criteria in 66 RCNY § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Jump" destination-name="T66C017_17-03" destination-id="0-0-0-17216">17-03</LINK>. The documentation types listed below are illustrative and not exhaustive.<LINEBRK/>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129878" number="111835" version="2049">
									<PARA>
										<TABLE>
											<TABLEFORMAT number-of-widths="2" left-border-space="0" left-border-width="30" left-border-color="#000000" right-border-space="0" right-border-width="30" right-border-color="#000000" top-border-space="0" top-border-width="30" top-border-color="#000000" bottom-border-space="0" bottom-border-width="30" bottom-border-color="#000000" horizontal-border-space="0" horizontal-border-width="15" horizontal-border-color="#000000" vertical-border-space="0" vertical-border-width="15" vertical-border-color="#000000">
												<COLUMNFORMAT column-width="252" percentage="no"/>
												<COLUMNFORMAT column-width="252" percentage="no"/>
											</TABLEFORMAT>
											<ROW>
												<COL>
													<PARA>
														<CELL header="true">
															<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">CATEGORY</CHARFORMAT>
														</CELL>
													</PARA>
												</COL>
												<COL>
													<PARA>
														<CELL header="true">
															<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">DOCUMENTATION TYPE</CHARFORMAT>
														</CELL>
													</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant is a small business and has no more than 500 employees</PARA>
												</COL>
												<COL>
													<PARA>Most recent tax return filed and signed Form 1120 – Line 1(a) (Gross receipts or sales), or other comparable tax form;<LINEBRK/>Most recent NY State Tax Form #45</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant operates an LMI small business</PARA>
												</COL>
												<COL>
													<PARA>For businesses in LMI Census tract areas: business address</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant operates a business with a North American Industry Classification System (NAICS) code that begins with 71 (Arts, Entertainment, and Recreation) or 72 (Accommodation and Food Services)</PARA>
												</COL>
												<COL>
													<PARA>Signed attestation</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant must demonstrate at least a 25% reduction in gross receipts or revenues</PARA>
												</COL>
												<COL>
													<PARA>Tax forms, financial statements (P&amp;L), bank statements</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant must be in substantial compliance with applicable Federal, State, and local laws, rules, and other legal requirements</PARA>
												</COL>
												<COL>
													<PARA>Signed attestation</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant must be current or in repayment on all Federal, State or City taxes (incl. delinquency repayment, prior to December 31, 2019)</PARA>
												</COL>
												<COL>
													<PARA>Signed attestation</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant did not receive a grant from any of the following programs: (1) Shuttered Venues Operator Grant Program, or (2) Restaurant Revitalization Fund</PARA>
												</COL>
												<COL>
													<PARA>Signed attestation</PARA>
												</COL>
											</ROW>
											<ROW>
												<COL>
													<PARA>Applicant intends to use grant funds to cover operating costs such as payroll, rent or utilities</PARA>
												</COL>
												<COL>
													<PARA>Signed attestation</PARA>
												</COL>
											</ROW>
										</TABLE>
									</PARA>
									<PARA>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129843" number="111836" version="2049">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Funding Priority:</CHARFORMAT> Funding will be released in rounds, with all eligible applicants funded in order of prioritization within each round. If there is insufficient funding available for all applicants in a given round, funding will be provided according to prioritization level and on a first-come, first-served basis within each prioritization level, based on the order in which applicants have submitted a complete application.<LINEBRK/>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-065]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-129879" number="111837" version="2049">
									<PARA>
										<TABLE>
											<TABLEFORMAT number-of-widths="4" left-border-space="0" left-border-width="30" left-border-color="#000000" right-border-space="0" right-border-width="30" right-border-color="#000000" top-border-space="0" top-border-width="30" top-border-color="#000000" bottom-border-space="0" bottom-border-width="30" bottom-border-color="#000000" horizontal-border-space="0" horizontal-border-width="15" horizontal-border-color="#000000" vertical-border-space="0" vertical-border-width="15" vertical-border-color="#000000">
												<COLUMNFORMAT column-width="72" percentage="no"/>
												<COLUMNFORMAT column-width="216" percentage="no"/>
												<COLUMNFORMAT column-width="216" percentage="no"/>
												<COLUMNFORMAT column-width="216" percentage="no"/>
											</TABLEFORMAT>
											<ROW>
												<COL>
													<PARA>
													</PARA>
												</COL>
												<COL>
													<PARA>
