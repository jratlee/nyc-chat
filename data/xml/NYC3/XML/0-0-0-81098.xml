						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-81099" number="93556" version="3">
								<HEADING>§ 4-01 Charge of Payment on Account of Insufficient Funds.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-10831" name="T43C004_4-01"/>§ 4-01 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Charge of Payment on Account of Insufficient Funds.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-81100" number="93557" version="3">
									<PARA>Pursuant to § 85 of the General Municipal Law, a charge of fifteen dollars per check may be added to any account owing to the City of New York or any of its agencies where a tendered payment of such account was by a check or other written order that was returned for insufficient funds.</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
