							<RECORD id="0-0-0-78375" number="89828" version="3">
								<HEADING>§ 17-02 Disposition of Assault Weapons by Permittees, Licensees and Previously Exempt Persons.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-10395" name="T38C017_17-02"/>§ 17-02 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Disposition of Assault Weapons by Permittees, Licensees and Previously Exempt Persons.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-78376" number="89829" version="1876">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Permittees, licensees and previously exempt persons, as described in Subdivision d of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="10-303.1" destination-id="0-0-0-0">10-303.1</LINK> of the New York City Administrative Code, shall, within ninety days of the effective date of these Rules, dispose of their assault weapons pursuant to such subdivision. All assault weapons possessed by such permittees, licensees and previously exempt persons shall be subject to the provisions of such subdivision, whether defined as assault weapons in subdivision 16 of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="10-301" destination-id="0-0-0-0">10-301</LINK> or in these Rules.</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
