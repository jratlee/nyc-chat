								<HEADING>§ 40-32 Prohibited Types of Water Heaters. [Repealed]</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-778" name="T01C040_40-32"/>§ 40-32 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Prohibited Types of Water Heaters. [Repealed]</CHARFORMAT>
