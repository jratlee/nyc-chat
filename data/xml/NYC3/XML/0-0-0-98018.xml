								<HEADING>§ 40-01 Installation and Maintenance of Gas-Fueled Water and Space Heaters in all Portions of Dwellings Used or Occupied for Living Purposes.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-762" name="T01C040_40-01"/>§ 40-01 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Installation and Maintenance of Gas-Fueled Water and Space Heaters in all Portions of Dwellings Used or Occupied for Living Purposes.</CHARFORMAT>
								</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-1770" number="1195" version="1772">
									<PARA>These rules shall govern the installation and maintenance of gas-fueled space and water heaters in the residence portions of multiple dwellings in the City of New York, including but not limited to the installation of such devices in multiple dwellings which are installed in lieu of centrally supplied heat and hot water under the provisions of § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="27-2028" destination-id="0-0-0-0">27-2028</LINK> and § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="27-2032" destination-id="0-0-0-0">27-2032</LINK> of the Administrative Code and in one and two family residences not heated by a central heating system.</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
