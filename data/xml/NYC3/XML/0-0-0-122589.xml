<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-122589" number="101284" version="1565">
			<HEADING>Chapter 12: Investigations and Complaints</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-16401" name="T52C012"/>Chapter 12: Investigations and Complaints</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-122590" number="101285" version="1567">
								<HEADING>§ 12-01 Investigations.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16611" name="T52C012_12-01"/>§ 12-01 Investigations.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-122591" number="101286" version="1887">
									<PARA>The Board may conduct an investigation into possible violations of the Charter, Act, or these rules. In its investigation, the Board may use its investigative powers pursuant to Section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="1813066185-672468487-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Charter.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="1052" destination-id="0-0-0-0">1052</LINK>(a)(5) of the Charter and §§ <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-708" destination-id="0-0-0-0">3-708</LINK>(5) and <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="3-710" destination-id="0-0-0-0">3-710</LINK>(1) of the Code. An investigation may include, but is not limited to, field investigations, desk and field audits, the issuance of subpoenas, the taking of sworn testimony, the issuance of document requests and interrogatories, and other methods of information gathering.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122592" number="101287" version="1566">
									<PARA>(Added City Record 8/16/2019, eff. 9/15/2019) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-041]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-122593" number="101288" version="1567">
								<HEADING>§ 12-02 Complaints.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-16613" name="T52C012_12-02"/>§ 12-02 Complaints.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-122594" number="101289" version="1565">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(a)<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Filing a complaint.</CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0"> A complaint must be filed by hand delivery, mail, fax, or scanned and sent as an attachment via email to the Board&apos;s offices.</CHARFORMAT>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-122595" number="101290" version="1565">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(b)<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Complaint requirements.</CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0"> Complaints must:</CHARFORMAT>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-122596" number="101291" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>be made in writing;</PARA>
								</RECORD>
								<RECORD id="0-0-0-122597" number="101292" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>be sworn to or affirmed;</PARA>
								</RECORD>
								<RECORD id="0-0-0-122598" number="101293" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iii)<TAB tab-count="1"/>be based on personal knowledge, if possible, and if a complaint is based on information and belief, the complainant must state the source of that information and belief;</PARA>
								</RECORD>
								<RECORD id="0-0-0-122599" number="101294" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iv)<TAB tab-count="1"/>specify the conduct alleged to be in violation of the Charter, Act, or these rules, and to the extent known:</PARA>
								</RECORD>
								<RECORD id="0-0-0-122600" number="101295" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(A)<TAB tab-count="1"/>the date(s) and time(s) of the conduct,</PARA>
								</RECORD>
								<RECORD id="0-0-0-122601" number="101296" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(B)<TAB tab-count="1"/>the place(s) the conduct occurred, and</PARA>
								</RECORD>
								<RECORD id="0-0-0-122602" number="101297" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(C)<TAB tab-count="1"/>the names of witnesses, if any.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122603" number="101298" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(v)<TAB tab-count="1"/>be accompanied by copies of all documentary evidence available to the complainant; and</PARA>
								</RECORD>
								<RECORD id="0-0-0-122604" number="101299" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(vi)<TAB tab-count="1"/>contain the complainant&apos;s full name, current address, telephone number, and email address.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122605" number="101300" version="1565">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(c)<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Initial review of complaint.</CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
										</CHARFORMAT>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-122606" number="101301" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>If in compliance. Upon receipt, the complaint will be reviewed for substantial compliance with the above requirements. If the complaint is in compliance, the Board shall, within 10 days of receipt, send each party complained about a copy of the complaint.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122607" number="101302" version="2807">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Deficient complaints.</CHARFORMAT> If the complaint is moot, facially meritless, or not in substantial compliance, it may be rejected, and the complainant so notified. The Board may investigate the subject matter of the complaint, but need not follow the procedural requirements of this chapter. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-122610" number="101303" version="2807">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(d)<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Response to complaint; possible dismissal.</CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
										</CHARFORMAT>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-122611" number="101304" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>The party complained about may submit an answer to the complaint:</PARA>
								</RECORD>
								<RECORD id="0-0-0-122612" number="101305" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(A) within 20 days of the date the complaint was sent by the Board, or</PARA>
								</RECORD>
								<RECORD id="0-0-0-122613" number="101306" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(B) within such lesser time as may be specified by the Board for complaints received less than 90 days before an election.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122614" number="101307" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>The answer must:</PARA>
								</RECORD>
								<RECORD id="0-0-0-122615" number="101308" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(A)<TAB tab-count="1"/>be sworn to and affirmed,</PARA>
								</RECORD>
								<RECORD id="0-0-0-122616" number="101309" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(B)<TAB tab-count="1"/>set forth a response to the allegations contained in the complaint, including any reasons why the Board should dismiss the complaint in full or in part, if applicable, and</PARA>
								</RECORD>
								<RECORD id="0-0-0-122617" number="101310" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(C)<TAB tab-count="1"/>be accompanied by copies of all documentary evidence available to the respondent.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122618" number="101311" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(iii)<TAB tab-count="1"/>Based on the answer, a complaint may be dismissed as moot.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122619" number="101312" version="1565">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(e)<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Board action.</CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0"> Based on its review of the complaint and any answer filed, and of any investigation it chooses to conduct, the Board may:</CHARFORMAT>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-122620" number="101313" version="1565">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(i)<TAB tab-count="1"/>determine the complaint to be moot or lacking in merit and dismiss the complaint; or</PARA>
								</RECORD>
								<RECORD id="0-0-0-122621" number="101314" version="1566">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(ii)<TAB tab-count="1"/>determine that violations or infractions of the Charter, Act, or these rules have been substantiated, and initiate an enforcement proceeding pursuant to the procedures outlined in 52 RCNY <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Jump" destination-name="T52C010" destination-id="0-0-0-16397">Chapter 10</LINK>.</PARA>
								</RECORD>
								<RECORD id="0-0-0-122622" number="101315" version="2807">
									<PARA>(Added City Record 8/16/2019, eff. 9/15/2019; amended City Record 11/19/2024, eff. 12/19/2024) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-104]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>