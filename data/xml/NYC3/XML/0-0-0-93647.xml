<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-93647" number="111483" version="3">
			<HEADING>Chapter 13: [Financial Hardship Waiver of Prohibition of Use of Certain Expanded Polystyrene Items]</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-13221" name="T66C013"/>Chapter 13: [Financial Hardship Waiver of Prohibition of Use of Certain Expanded Polystyrene Items]</PARA>
		</RECORD>
		<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
			<RECORD id="0-0-0-93649" number="111484" version="757">
				<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-20">
					<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Editor&apos;s notes:</CHARFORMAT> the bracketed chapter title above was provided by the editor as an aid for the user and is not an official part of the rule as promulgated by DSBS. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
				</PARA>
			</RECORD>
			<RECORD id="0-0-0-93650" number="111485" version="1893">
				<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-20">The waiver described in this chapter pertains to provisions and requirements set forth in Administrative Code § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="16-329" destination-id="0-0-0-0">16-329</LINK>. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
				</PARA>
			</RECORD>
		</LEVEL>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-93651" number="111486" version="3">
								<HEADING>§ 13-01 Definitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-13223" name="T66C012_13-01"/>§ 13-01 Definitions.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-93652" number="111487" version="3">
									<PARA>As used in these rules, the following terms shall have the following meanings: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93653" number="111488" version="3">
									<PARA>
										<TAB tab-count="1"/>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Applicant </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means a business or not-for-profit corporation which has applied for a financial hardship waiver.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93654" number="111489" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Business </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means any food service establishment, mobile food commissary, or store that is not a not-for-profit corporation.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93655" number="111490" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Acknowledgement Letter </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means the letter sent by DSBS to an applicant notifying the applicant of its pending application for a financial hardship waiver.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93656" number="111491" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">City </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means the City of New York.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93657" number="111492" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Commissioner </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means the Commissioner of the New York City Department of Small Business Services or his or her designee or his or her successor in function.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93658" number="111493" version="1893">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Comparable alternative product </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means a product to be used by the business or not-for-profit corporation in place of an expanded polystyrene single service item prohibited by </CHARFORMAT>§<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">&#160;<LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="16-329" destination-id="0-0-0-0">16-329</LINK> of the Administrative Code or any successor provision.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93659" number="111494" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Day </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means a calendar day unless otherwise specified.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93660" number="111495" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Denial </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">or </CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Denied </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means a determination by DSBS that an applicant is not eligible for a financial hardship waiver.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93661" number="111496" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">DSBS </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means the New York City Department of Small Business Services or its successor in function.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93662" number="111497" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">DSNY </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means the New York City Department of Sanitation or its successor in function.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93663" number="111498" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">DSNY Commissioner </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means the commissioner of the New York City Department of Sanitation or his/her designee or his/her successor in function.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93664" number="111499" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Expanded polystyrene </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means blown polystyrene and expanded and extruded foams that are thermoplastic petrochemical materials utilizing a styrene monomer and processed by any number of techniques including, but not limited to, fusion of polymer spheres (expandable bead foam), injection molding, foam molding, and extrusion-blown molding (extruded foam polystyrene). Such term shall not include rigid polystyrene.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">&#160;</CHARFORMAT>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93665" number="111500" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Food service establishment </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means a premises or part of a premises where food is provided directly to the consumer whether such food is provided free of charge or sold, and whether consumption occurs on or off the premises or is provided from a pushcart, stand or vehicle. Food service establishment shall include, but not be limited to, full-service restaurants, fast food restaurants, cafes, delicatessens, coffee shops, grocery stores, vending trucks or carts and cafeterias.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93666" number="111501" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Mobile food commissary </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means any facility that:</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">&#160;</CHARFORMAT>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93667" number="111502" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>1.<TAB tab-count="1"/>disposes of solid waste generated by the operation of a food service establishment that is located in or is a pushcart, stand or vehicle; or</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93668" number="111503" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>2.<TAB tab-count="1"/>supplies potable water and food, whether pre-packaged or prepared at the mobile food commissary, and supplies non-food items.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93669" number="111504" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Store </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means a retail or wholesale establishment other than a food service establishment.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93670" number="111505" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
										</CHARFORMAT>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Undue financial hardship </CHARFORMAT>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">means that an applicant has demonstrated any of the following, based on submitted financial projections:</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93671" number="111506" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>1.<TAB tab-count="1"/>The cost of using a comparable alternative product will result in an increase of more than 5% of the business&apos;s annual cost of operations;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93672" number="111507" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>2.<TAB tab-count="1"/>The increased costs will result in the elimination of at least one employee; or</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93673" number="111508" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>3.<TAB tab-count="1"/>The increased cost will result in a reduction in annual net profit of more than 5%.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93674" number="111509" version="39">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">(Added City Record 6/23/2015, eff. 7/23/2015)</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-93675" number="111510" version="3">
								<HEADING>§ 13-02 Application for a Waiver.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-13225" name="T66C012_13-02"/>§ 13-02 Application for a Waiver.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-93676" number="111511" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(a)<TAB tab-count="1"/>To be eligible for consideration of a financial hardship waiver, a business must:</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93677" number="111512" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(1)<TAB tab-count="1"/>Submit its tax returns for the most recent tax year, which must demonstrate that the business had an annual gross income of less than five hundred thousand dollars per location for such year;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93678" number="111513" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(2)<TAB tab-count="1"/>Provide a list of expanded polystyrene single service items used by the business for which a waiver is sought;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93679" number="111514" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(3)<TAB tab-count="1"/>Provide a list of comparable alternative products that cost more than the expanded polystyrene single service items the business currently uses;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93680" number="111515" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(4)<TAB tab-count="1"/>Provide a detailed explanation of why the use of comparable alternative products creates an undue financial hardship for the business; and,</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93681" number="111516" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(5)<TAB tab-count="1"/>Provide any additional information related to the waiver request as requested by DSBS or DSNY.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93682" number="111517" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(b)<TAB tab-count="1"/>Applicants that are not-for-profit corporations must:</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93683" number="111518" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(1)<TAB tab-count="1"/>Submit a certificate of incorporation demonstrating that the applicant is a not-for-profit corporation;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93684" number="111519" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(2)<TAB tab-count="1"/>Submit a current Form 990 filed with the Internal Revenue Service;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93685" number="111520" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(3)<TAB tab-count="1"/>Provide a list of expanded polystyrene single service items used by the not-for-profit corporation for which a waiver is sought;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93686" number="111521" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(4)<TAB tab-count="1"/>Provide a list of comparable alternative products that cost more than the expanded polystyrene single service items the not-for-profit corporation currently uses;</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93687" number="111522" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(5)<TAB tab-count="1"/>Provide a detailed explanation of why the use of comparable alternative products creates an undue financial hardship for the not-for-profit corporation; and</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93688" number="111523" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>
											<TAB tab-count="1"/>(6)<TAB tab-count="1"/>Provide any additional information related to the waiver request as requested by DSBS or DSNY.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93689" number="111524" version="39">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">(Added City Record 6/23/2015, eff. 7/23/2015)</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-93690" number="111525" version="3">
								<HEADING>§ 13-03. Waiver Determinations.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-13227" name="T66C012_13-03"/>§ 13-03. Waiver Determinations.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-93691" number="111526" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Determinations by the DSBS Commissioner approving or denying an applicant&apos;s waiver request, made in consultation with the DSNY Commissioner, shall be made in writing on the basis of all the circumstances presented by the applicant.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93692" number="111527" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(b)<TAB tab-count="1"/>A copy of the waiver determination shall be sent to the applicant and filed with DSBS and DSNY. Such determinations shall be made available for public inspection upon request.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93693" number="111528" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(c)<TAB tab-count="1"/>Waivers shall be valid for twelve months from the date of determination and shall be renewable upon written application to DSBS. All determinations shall be final.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93694" number="111529" version="2306">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(d)<TAB tab-count="1"/>Applicants receiving a denial of a waiver request may reapply after twelve months from the date of the denial of the initial application. Applicants receiving a denial of a waiver request or a renewal request shall have two months from the date of the denial to come into compliance with § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="16-329" destination-id="0-0-0-0">16-329</LINK> of the Administrative Code.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93695" number="111530" version="1893">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>(e)<TAB tab-count="1"/>DSBS will send applicants an acknowledgment letter notifying the applicant of receipt of its pending application for a financial hardship waiver within twenty calendar days from the date of receipt of a waiver request application. A pending application for a financial hardship waiver or application for renewal of a waiver shall be a defense to any notice of violation issued pursuant to </CHARFORMAT>§<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">&#160;<LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="16-329" destination-id="0-0-0-0">16-329</LINK> Administrative Code to which such pending application relates and such notice of violation shall be dismissed.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93696" number="111531" version="39">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">(Added City Record 6/23/2015, eff. 7/23/2015)</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-93697" number="111532" version="3">
								<HEADING>§ 13-04. Renewals.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-13229" name="T66C012_13-04"/>§ 13-04. Renewals.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-93698" number="111533" version="3">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">
											<TAB tab-count="1"/>A business may request renewal of a waiver no later than 30 days before the termination date of the waiver. A request for renewal shall certify that there has been no material change with respect to the relevant facts or circumstances that existed at the time the initial waiver was granted. Any application submitted after the termination date or less than 30 days before the termination date of the waiver shall be treated as a new application.</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-93699" number="111534" version="39">
									<PARA>
										<CHARFORMAT bold="0" italic="0" underline="0" strike-out="0" hidden="0">(Added City Record 6/23/2015, eff. 7/23/2015)</CHARFORMAT>&#160;<HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-001]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>