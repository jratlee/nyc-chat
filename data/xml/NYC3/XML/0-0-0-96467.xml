<DOCUMENT source-infobase-name="Rules" content-collection-id="NYCrules" source-infobase-title="The Rules of the City of New York" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\NYCrules.mak" css-stylesheet-href="#!-- #ID=NYCrules_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCrules\output\HUCCVLERTKEUARDR\XML\" css-stylesheet-name="NYCrules_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-477" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-96467" number="36471" version="2194">
			<HEADING>Chapter 60: Rulemaking Petitions</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-17476" name="T15C060"/>Chapter 60: Rulemaking Petitions</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-480" level-depth="3" toc-section="false">
			<LEVEL style-name="Subtitle" style-name-escaped="Subtitle" style-id="0-0-0-15301" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-483" level-depth="5" toc-section="false">
					<LEVEL style-name="Subpart" style-name-escaped="Subpart" style-id="0-0-0-15960" level-depth="6" toc-section="false">
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-132053" number="36472" version="2194">
								<HEADING>§ 60-01 Scope.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17478" name="T15C060_60-01"/>§ 60-01 Scope.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-132075" number="36473" version="2194">
									<PARA>These Rules and Regulations govern the procedures by which the public may submit to an Agency Petitions for Rulemaking pursuant to § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="1813066185-672468487-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Charter.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="1043" destination-id="0-0-0-0">1043</LINK>(g) of the New York City Charter (City Administrative Procedures Act) and the procedures for Agency consideration and disposition of such Petitions. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132074" number="36474" version="2194">
									<PARA>(Added City Record 2/9/2022, eff. 3/11/2022) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-132078" number="36475" version="2194">
								<HEADING>§ 60-02 Definitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17480" name="T15C060_60-02"/>§ 60-02 Definitions.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-132073" number="36476" version="2502">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">City Administrative Procedures Act (CAPA).</CHARFORMAT> &quot;City Administrative Procedures Act (CAPA)&quot; means the requirements for rulemaking by agencies of the City of New York specified in <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="1813066185-672468487-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Charter.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="Chapter 45" destination-id="0-0-0-0">Chapter 45</LINK> of the New York City Charter. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132072" number="36477" version="2502">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Department.</CHARFORMAT> &quot;Department&quot; means the Department of Environmental Protection. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132071" number="36478" version="2502">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Person.</CHARFORMAT> &quot;Person&quot; means an individual, partnership, corporation or other legal entity, and any individual or entity acting in a fiduciary or representative capacity. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132070" number="36479" version="2502">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Petition.</CHARFORMAT> Petition&quot; means a request or application for the Department to adopt a Rule. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132069" number="36480" version="2502">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Petitioner.</CHARFORMAT> &quot;Petitioner&quot; means the person who files a Petition. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132068" number="36481" version="2502">
									<PARA>
										<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Rule.</CHARFORMAT> Rule&quot; has the same meaning as in § <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-31" type="Inter Infobase Jump" destination-infobase-id="1813066185-672468487-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Charter.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="1041" destination-id="0-0-0-0">1041</LINK>(5) of the New York City Charter (City Administrative Procedure Act) (CAPA). <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132067" number="36482" version="2194">
									<PARA>(Added City Record 2/9/2022, eff. 3/11/2022) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-132077" number="36483" version="2194">
								<HEADING>§ 60-03 Procedures for Submitting Petitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17482" name="T15C060_60-03"/>§ 60-03 Procedures for Submitting Petitions.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-132066" number="36484" version="2194">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Any Person may petition the Department to consider the adoption of a Rule. The Petition must include: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132065" number="36485" version="2194">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(1)<TAB tab-count="1"/>The Rule to be considered, with proposed language for adoption; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132064" number="36486" version="2497">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(2)<TAB tab-count="1"/>Petitioner&apos;s arguments in support of adoption of the Rule; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132063" number="36487" version="2194">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(3)<TAB tab-count="1"/>The name, address, telephone number, and email address of the Petitioner or his or her authorized representative; <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132062" number="36488" version="2194">
									<PARA>
										<TAB tab-count="1"/>
										<TAB tab-count="1"/>(4)<TAB tab-count="1"/>The signature of Petitioner or his or her representative. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132061" number="36489" version="2194">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>Any change in the name, address or telephone number of the Petitioner or his or her authorized representative must be reported to the office to which the Petition was submitted. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132060" number="36490" version="2194">
									<PARA>
										<TAB tab-count="1"/>(c)<TAB tab-count="1"/>All Petitions should be typewritten, if possible, but handwritten Petitions will be accepted provided they are legible. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132059" number="36491" version="2194">
									<PARA>
										<TAB tab-count="1"/>(d)<TAB tab-count="1"/>Petitions must be submitted by email to nycrules@dep.nyc.gov or by mailing or delivering the Petition to the DEP Bureau of Legal Affairs, 59-17 Junction Boulevard 19th Floor, Flushing NY 11373. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132058" number="36492" version="2194">
									<PARA>(Added City Record 2/9/2022, eff. 3/11/2022) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
						<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-486" level-depth="7" toc-section="true">
							<RECORD id="0-0-0-132076" number="36493" version="2194">
								<HEADING>§ 60-04 Procedures for Consideration of and Responses to Petitions.</HEADING>
								<PARA>
									<DESTINATION id="0-0-0-17484" name="T15C060_60-04"/>§ 60-04 Procedures for Consideration of and Responses to Petitions.</PARA>
							</RECORD>
							<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
								<RECORD id="0-0-0-132057" number="36494" version="2194">
									<PARA>When a Petition submitted in proper form is received, within 60 days from the date the Petition was received, the Department must either: <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132056" number="36495" version="2194">
									<PARA>
										<TAB tab-count="1"/>(a)<TAB tab-count="1"/>Deny such Petition in a written statement containing the reasons for denial; or <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132055" number="36496" version="2497">
									<PARA>
										<TAB tab-count="1"/>(b)<TAB tab-count="1"/>Approve the Petition and state in writing the Department&apos;s intention to grant the Petition and to initiate Rulemaking by a specified date. The Department is not required to grant the entirety of a Petition and is not bound by the language proposed by Petitioner but may amend or modify such proposed language at the Department&apos;s discretion. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
								<RECORD id="0-0-0-132052" number="36497" version="2237">
									<PARA>(Added City Record 2/9/2022, eff. 3/11/2022) <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-33">[ALP S-070]</HIGHLIGHTER>
									</PARA>
								</RECORD>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>