<DOCUMENT source-infobase-name="Admin" content-collection-id="NYCadmin" source-infobase-title="New York City Administrative Code" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\NYCadmin.mak" css-stylesheet-href="#!-- #ID=NYCadmin_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\XML\" css-stylesheet-name="NYCadmin_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-685" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-47782" number="60744" version="3">
			<HEADING>Chapter 11: Housing Information Guide for Tenants and Owners</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-11683" name="T26C011"/>Chapter 11: Housing Information Guide for Tenants and Owners</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-688" level-depth="3" toc-section="false">
			<LEVEL style-name="Appendix" style-name-escaped="Appendix" style-id="0-0-0-691" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-694" level-depth="5" toc-section="false">
					<LEVEL style-name="Article" style-name-escaped="Article" style-id="0-0-0-697" level-depth="6" toc-section="false">
						<LEVEL style-name="Subarticle" style-name-escaped="Subarticle" style-id="0-0-0-700" level-depth="7" toc-section="false">
							<LEVEL style-name="Subarticle - Part" style-name-escaped="Subarticle---Part" style-id="0-0-0-29474" level-depth="8" toc-section="false">
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-47783" number="60745" version="3">
										<HEADING>§ 26-1101 Definitions.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-11685" name="26-1101"/>§ 26-1101 Definitions.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-47784" number="60746" version="3">
											<PARA>For purposes of this chapter, the following terms are defined as follows: <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47785" number="60747" version="3">
											<PARA>
												<TAB tab-count="1"/>&quot;Department&quot; means the department of housing preservation and development. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47786" number="60748" version="3">
											<PARA>
												<TAB tab-count="1"/>&quot;Dwelling unit&quot; means a dwelling unit as defined in paragraph thirteen of subdivision a of section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="27-2004" destination-id="0-0-0-2989">27-2004</LINK> of the code. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47787" number="60749" version="3">
											<PARA>
												<TAB tab-count="1"/>&quot;Multiple dwelling&quot; means a dwelling as defined in paragraph seven of subdivision a of section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="27-2004" destination-id="0-0-0-2989">27-2004</LINK> of the code. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47788" number="60750" version="3">
											<PARA>
												<TAB tab-count="1"/>&quot;Owner&quot; means an owner as defined in paragraph forty-five of subdivision a of section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="27-2004" destination-id="0-0-0-2989">27-2004</LINK> of the code. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47789" number="60751" version="3">
											<PARA>
												<TAB tab-count="1"/>&quot;Tenant&quot; means any lawful occupant of a dwelling unit in a multiple dwelling. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-47790" number="60752" version="3">
										<HEADING>§ 26-1102 Housing information guide for tenants and owners.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-11687" name="26-1102"/>§ 26-1102 Housing information guide for tenants and owners.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-47791" number="60753" version="3">
											<PARA>
												<TAB tab-count="1"/>a.<TAB tab-count="1"/>The department shall maintain a housing information guide for tenants and owners in English, Spanish and, in the discretion of the department, other languages. Such guide shall be available on the department&apos;s website and shall be available in printed form upon request. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47792" number="60754" version="3">
											<PARA>
												<TAB tab-count="1"/>b.<TAB tab-count="1"/>The guide maintained pursuant to this section shall include, but not be limited to, information about: <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47793" number="60755" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>(1)<TAB tab-count="1"/>owners&apos; responsibilities with respect to eviction, heat and hot water, pest management, repairs and maintenance, tenant organizations, rent-regulated leases, rental assistance for elderly or disabled tenants, and housing discrimination; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47794" number="60756" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>(2)<TAB tab-count="1"/>tenants&apos; responsibilities with respect to responding to required notices, allowing access for inspections and repairs, and not causing violations; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47795" number="60757" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>(3)<TAB tab-count="1"/>the availability of free and low-cost legal services; and <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47796" number="60758" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>(4)<TAB tab-count="1"/>other topics deemed relevant by the department. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-47797" number="60759" version="3">
										<HEADING>§ 26-1103 Notice of housing information guide for tenants and owners.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-11689" name="26-1103"/>§ 26-1103 Notice of housing information guide for tenants and owners.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-47798" number="60760" version="3">
											<PARA>
												<TAB tab-count="1"/>a.<TAB tab-count="1"/>
												<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Posting required.</CHARFORMAT> Every owner of a multiple dwelling shall post a notice in English and Spanish regarding the availability of the housing information guide for tenants and owners maintained pursuant to section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="26-1102" destination-id="0-0-0-11687">26-1102</LINK> of this chapter. Such notice shall be posted in a conspicuous place within view of the area in the multiple dwelling to which mail is delivered. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47799" number="60761" version="3">
											<PARA>
												<TAB tab-count="1"/>b.<TAB tab-count="1"/>Upon request by a tenant occupying a dwelling unit in a multiple dwelling, the owner of such multiple dwelling shall make best efforts to provide the notice required by subdivision a in a language other than English or Spanish. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47800" number="60762" version="3">
											<PARA>
												<TAB tab-count="1"/>c.<TAB tab-count="1"/>The notice required by subdivision a of this section shall, at a minimum, indicate that the guide maintained pursuant to section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="26-1102" destination-id="0-0-0-11687">26-1102</LINK> of this chapter includes information about: <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47801" number="60763" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>(1)<TAB tab-count="1"/>owners&apos; responsibilities with respect to eviction, heat and hot water, pest management, repairs and maintenance, tenant organizations, rent-regulated leases, rental assistance for elderly or disabled tenants, and housing discrimination; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47802" number="60764" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>(2)<TAB tab-count="1"/>topics related to tenants&apos; responsibilities; and <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47803" number="60765" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>(3)<TAB tab-count="1"/>the availability of free and low-cost legal services. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-47804" number="60766" version="3">
											<PARA>
												<TAB tab-count="1"/>d.<TAB tab-count="1"/>
												<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Contents of posted notice.</CHARFORMAT> The department shall determine the form of the notice required pursuant to subdivision a of this section. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-47805" number="60767" version="3">
										<HEADING>§ 26-1104 Violations and penalties.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-11691" name="26-1104"/>§ 26-1104 Violations and penalties.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-47806" number="60768" version="3">
											<PARA>Any owner who violates the provisions of subdivision a of section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="26-1103" destination-id="0-0-0-11689">26-1103</LINK> of this chapter shall be liable for a civil penalty of two hundred fifty dollars. For purposes of this section, each multiple dwelling in which an owner fails to post the notice required pursuant to subdivision a of section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="26-1103" destination-id="0-0-0-11689">26-1103</LINK> of this chapter shall be deemed a separate violation. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-010]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>