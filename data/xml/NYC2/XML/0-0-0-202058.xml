										<HEADING>§ 21-1000 Distribution of information regarding suicide prevention.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-24508" name="21-1000"/>§ 21-1000 Distribution of information regarding suicide prevention.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-202065" number="49981" version="1765">
											<PARA>
												<TAB tab-count="1"/>a.<TAB tab-count="1"/>
												<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Definitions.</CHARFORMAT> For purposes of this section, the term &quot;school&quot; means a school of the city school district of the city of New York. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-080]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-202064" number="49982" version="1274">
											<PARA>
												<TAB tab-count="1"/>b.<TAB tab-count="1"/>No later than September 15, 2023, and annually thereafter, the department shall distribute to each school, to be shared with every student of such school, the following information in writing, in hard copy, or electronically if availability of similar documents occurs electronically, using plain, simple, and age-appropriate language: <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-080]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-202063" number="49983" version="1274">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>1.<TAB tab-count="1"/>The 988 suicide and crisis lifeline number; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-080]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-202062" number="49984" version="1274">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>2.<TAB tab-count="1"/>Information about suicide, including warning signs, risk factors, and prevention; and <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-080]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-202061" number="49985" version="1274">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>3.<TAB tab-count="1"/>Any other information that the department deems relevant. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-080]</HIGHLIGHTER>
											</PARA>
