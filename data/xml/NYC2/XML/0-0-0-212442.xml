<DOCUMENT source-infobase-name="Admin" content-collection-id="NYCadmin" source-infobase-title="New York City Administrative Code" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\NYCadmin.mak" css-stylesheet-href="#!-- #ID=NYCadmin_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\XML\" css-stylesheet-name="NYCadmin_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-685" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-212442" number="18635" version="1509">
			<HEADING>Chapter 23-C: Wireless Communications Surcharge</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-4353" name="T11C023-c"/>Chapter 23-C: Wireless Communications Surcharge</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-688" level-depth="3" toc-section="false">
			<LEVEL style-name="Appendix" style-name-escaped="Appendix" style-id="0-0-0-691" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-694" level-depth="5" toc-section="false">
					<LEVEL style-name="Article" style-name-escaped="Article" style-id="0-0-0-697" level-depth="6" toc-section="false">
						<LEVEL style-name="Subarticle" style-name-escaped="Subarticle" style-id="0-0-0-700" level-depth="7" toc-section="false">
							<LEVEL style-name="Subarticle - Part" style-name-escaped="Subarticle---Part" style-id="0-0-0-29474" level-depth="8" toc-section="false">
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-15361" number="18636" version="3">
										<HEADING>§ 11-2351 Surcharge on wireless communications service.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-4355" name="11-2351"/>§ 11-2351 Surcharge on wireless communications service.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-15362" number="18637" version="3">
											<PARA>
												<TAB tab-count="1"/>(a)<TAB tab-count="1"/>There is hereby imposed within the territorial limits of the city of New York, in accordance with the provisions of section 186-g of the tax law, a surcharge on wireless communications service, as such surcharge is described in paragraph (b) of subdivision 2 of section 186-g of the tax law.</PARA>
										</RECORD>
										<RECORD id="0-0-0-15363" number="18638" version="3">
											<PARA>
												<TAB tab-count="1"/>(b)<TAB tab-count="1"/>Such surcharge shall be imposed at the rate of thirty cents per month on each wireless communications device in service during any part of the month.</PARA>
										</RECORD>
										<RECORD id="0-0-0-15364" number="18639" version="3">
											<PARA>
												<TAB tab-count="1"/>(c)<TAB tab-count="1"/>A wireless communications service supplier shall begin to add such surcharge to the billings of its customers on December 1, 2017.</PARA>
										</RECORD>
										<RECORD id="0-0-0-15365" number="18640" version="3">
											<PARA>(L.L. 2017/139, 8/25/2017, eff. 12/1/2017) <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-016]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-15366" number="18641" version="3">
										<HEADING>§ 11-2352 Surcharge on the retail sale of each prepaid wireless communications service.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-4357" name="11-2352"/>§ 11-2352 Surcharge on the retail sale of each prepaid wireless communications service.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-15367" number="18642" version="3">
											<PARA>
												<TAB tab-count="1"/>(a)<TAB tab-count="1"/>There is hereby imposed within the territorial limits of the city of New York, in accordance with the provisions of section 186-g of the tax law, a surcharge on prepaid wireless communications service, as such surcharge is described in paragraph (c) of subdivision 2 of section 186-g of the tax law.</PARA>
										</RECORD>
										<RECORD id="0-0-0-15368" number="18643" version="3">
											<PARA>
												<TAB tab-count="1"/>(b)<TAB tab-count="1"/>Such surcharge shall be imposed at the rate of thirty cents per retail sale.</PARA>
										</RECORD>
										<RECORD id="0-0-0-15369" number="18644" version="3">
											<PARA>
												<TAB tab-count="1"/>(c)<TAB tab-count="1"/>A prepaid wireless communications seller shall begin to collect such surcharge from its customers on December 1, 2017.</PARA>
										</RECORD>
										<RECORD id="0-0-0-15370" number="18645" version="3">
											<PARA>(L.L. 2017/139, 8/25/2017, eff. 12/1/2017) <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-016]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>