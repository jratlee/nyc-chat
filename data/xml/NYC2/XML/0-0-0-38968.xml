						<LEVEL style-name="Subarticle" style-name-escaped="Subarticle" style-id="0-0-0-700" level-depth="7" toc-section="false">
							<LEVEL style-name="Subarticle - Part" style-name-escaped="Subarticle---Part" style-id="0-0-0-29474" level-depth="8" toc-section="false">
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-38969" number="49818" version="3">
										<HEADING>§ 21-989 Posting of subdistrict maps.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-9811" name="21-989"/>§ 21-989 Posting of subdistrict maps.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-38970" number="49819" version="1765">
											<PARA>
												<TAB tab-count="1"/>a.<TAB tab-count="1"/>
												<CHARFORMAT bold="0" italic="1" underline="0" strike-out="0" hidden="0">Definitions.</CHARFORMAT> For the purposes of this section, the term &quot;<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">subdistrict</CHARFORMAT>&quot; means all geographic boundaries used by the department and the New York city school construction authority to identify where new capital funding will be targeted for building new schools. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-030]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-38971" number="49820" version="3">
											<PARA>
												<TAB tab-count="1"/>b.<TAB tab-count="1"/>The department shall post conspicuously on its website a map indicating the boundaries and associated identifiers of all subdistricts in the city school district of the city of New York. Such map shall be posted in a machine readable geographic format. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-030]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-38972" number="49821" version="709">
											<PARA>(L.L. 2018/165, 10/13/2018, eff. 10/13/2018) <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-030]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
							</LEVEL>
						</LEVEL>
					</LEVEL>
