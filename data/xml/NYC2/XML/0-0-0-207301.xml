<DOCUMENT source-infobase-name="Admin" content-collection-id="NYCadmin" source-infobase-title="New York City Administrative Code" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\NYCadmin.mak" css-stylesheet-href="#!-- #ID=NYCadmin_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\XML\" css-stylesheet-name="NYCadmin_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-685" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-207301" number="128794" version="1427">
			<HEADING>Chapter 1: Enactment of the New York City Fire Code</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-18119" name="T29C001"/>Chapter 1: Enactment of the New York City Fire Code</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-688" level-depth="3" toc-section="false">
			<LEVEL style-name="Appendix" style-name-escaped="Appendix" style-id="0-0-0-691" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-694" level-depth="5" toc-section="false">
					<LEVEL style-name="Article" style-name-escaped="Article" style-id="0-0-0-697" level-depth="6" toc-section="false">
						<LEVEL style-name="Subarticle" style-name-escaped="Subarticle" style-id="0-0-0-700" level-depth="7" toc-section="false">
							<LEVEL style-name="Subarticle - Part" style-name-escaped="Subarticle---Part" style-id="0-0-0-29474" level-depth="8" toc-section="false">
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-139889" number="128795" version="1184">
										<HEADING>§ 29-101 Short title. </HEADING>
										<PARA>
											<DESTINATION id="0-0-0-18121" name="29-101"/>§ 29-101 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Short title. </CHARFORMAT>
										</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-139890" number="128796" version="1184">
											<PARA>This title shall be known as and may be cited as the &quot;New York city fire code&quot; or the &quot;fire code.&quot;</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-139891" number="128797" version="1184">
										<HEADING>§ 29-102 Enactment. </HEADING>
										<PARA>
											<DESTINATION id="0-0-0-18123" name="29-102"/>§ 29-102 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Enactment. </CHARFORMAT>
										</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-139892" number="128798" version="1184">
											<PARA>The New York city fire code, based on the 2003 edition* of the International Fire Code published by the International Code Council, with amendments reflecting the unique character of the city, is hereby enacted to read as set forth in <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="T29C002" destination-id="0-0-0-18125">Chapter 2</LINK> of this title.</PARA>
										</RECORD>
										<RECORD id="0-0-0-139893" number="128799" version="1757">
											<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-18">
												<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">* Editor&apos;s note: </CHARFORMAT>the most recent amendments to the New York City Fire Code, set forth in <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="T29C002" destination-id="0-0-0-18125">Chapter 2</LINK> and enacted by L.L. 2022/047, 1/15/2022, eff. 4/15/2022, are based on the 2015 edition of the International Fire Code. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-072]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-139894" number="128800" version="1184">
										<HEADING>§ 29-103 Enforcement. </HEADING>
										<PARA>
											<DESTINATION id="0-0-0-18127" name="29-103"/>§ 29-103 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Enforcement. </CHARFORMAT>
										</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-139895" number="128801" version="1184">
											<PARA>The fire commissioner shall be responsible for the administration and enforcement of the fire code.</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-139896" number="128802" version="1184">
										<HEADING>§ 29-104 Periodic review and amendment. </HEADING>
										<PARA>
											<DESTINATION id="0-0-0-18129" name="29-104"/>§ 29-104 <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Periodic review and amendment. </CHARFORMAT>
										</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-139897" number="128803" version="1184">
											<PARA>No later than the third year after the effective date of this title and every third year thereafter, the fire commissioner shall review the latest edition of the International Fire Code and submit to the city council such proposed amendments as he or she may determine should be made to the fire code based upon such model code.</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>