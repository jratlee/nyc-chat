<DOCUMENT source-infobase-name="Admin" content-collection-id="NYCadmin" source-infobase-title="New York City Administrative Code" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\NYCadmin.mak" css-stylesheet-href="#!-- #ID=NYCadmin_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCadmin\output\QYOUGRVBABWOEQAB\XML\" css-stylesheet-name="NYCadmin_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-685" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-42783" number="54636" version="3">
			<HEADING>Chapter 7: Department of Health and Mental Hygiene</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-10247" name="T23C007"/>Chapter 7: Department of Health and Mental Hygiene</PARA>
		</RECORD>
		<LEVEL style-name="Subchapter" style-name-escaped="Subchapter" style-id="0-0-0-688" level-depth="3" toc-section="false">
			<LEVEL style-name="Appendix" style-name-escaped="Appendix" style-id="0-0-0-691" level-depth="4" toc-section="false">
				<LEVEL style-name="Part" style-name-escaped="Part" style-id="0-0-0-694" level-depth="5" toc-section="false">
					<LEVEL style-name="Article" style-name-escaped="Article" style-id="0-0-0-697" level-depth="6" toc-section="false">
						<LEVEL style-name="Subarticle" style-name-escaped="Subarticle" style-id="0-0-0-700" level-depth="7" toc-section="false">
							<LEVEL style-name="Subarticle - Part" style-name-escaped="Subarticle---Part" style-id="0-0-0-29474" level-depth="8" toc-section="false">
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-42784" number="54637" version="3">
										<HEADING>§ 23-701. Restaurant inspection data.</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-10249" name="23-701"/>§ 23-701. Restaurant inspection data.</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-42785" number="54638" version="609">
											<PARA>For so long as the department operates a letter grading system for sanitary inspection results, as provided in sections <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Inter Infobase Jump" destination-infobase-id="381572687-333571626-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Rules.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="T24C023_23-03" destination-id="0-0-0-0">23-03</LINK>, <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Inter Infobase Jump" destination-infobase-id="381572687-333571626-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Rules.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="T24C023_23-04" destination-id="0-0-0-0">23-04</LINK> of the rules of the city of New York, and <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Inter Infobase Jump" destination-infobase-id="381572687-333571626-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Rules.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="T24HC_81.51" destination-id="0-0-0-0">81.51 </LINK>of the New York city health code, the following data for each sanitary inspection conducted at a food service establishment shall be collected and reported in accordance with section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Jump" destination-name="23-505" destination-id="0-0-0-10229">23-505</LINK> of this code and any rules promulgated thereunder: <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-015]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42786" number="54639" version="609">
											<PARA>
												<TAB tab-count="1"/>a.<TAB tab-count="1"/>the inspection type as defined in section <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Inter Infobase Jump" destination-infobase-id="381572687-333571626-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Rules.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="T24C023_23-01" destination-id="0-0-0-0">23-01</LINK> of the rules of the city of New York; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-015]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42787" number="54640" version="3">
											<PARA>
												<TAB tab-count="1"/>b.<TAB tab-count="1"/>each violation cited and the number of points allocated per violation; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-015]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42788" number="54641" version="3">
											<PARA>
												<TAB tab-count="1"/>c.<TAB tab-count="1"/>total score awarded upon inspection, or, if such inspection result is contested in an administrative tribunal, after adjudication; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-015]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42789" number="54642" version="3">
											<PARA>
												<TAB tab-count="1"/>d.<TAB tab-count="1"/>the date of any such adjudication; and <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-015]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42790" number="54643" version="3">
											<PARA>
												<TAB tab-count="1"/>e.<TAB tab-count="1"/>if monetary penalties are assessed, the amount of such penalty. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-015]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-42791" number="54644" version="3">
										<HEADING>§ 23-702 School food service establishment inspection results.*</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-10251" name="23-702"/>§ 23-702 School food service establishment inspection results.*</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-42792" number="54645" version="3">
											<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-18">* <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Editor&apos;s note:</CHARFORMAT> there are two sections designated as § 23-702. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42793" number="54646" version="1765">
											<PARA>
												<TAB tab-count="1"/>a.<TAB tab-count="1"/>For the purposes of this section the term &quot;school food service establishment&quot; means a cafeteria or kitchen in a school that is subject to the provisions of <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-23" type="Inter Infobase Jump" destination-infobase-id="381572687-333571626-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Rules.NFO" destination-infobase-name="" destination-infobase-title="" destination-name="T24HC_81.00" destination-id="0-0-0-0">article 81</LINK> of title 24 of the New York city health code.</PARA>
										</RECORD>
										<RECORD id="0-0-0-42794" number="54647" version="1762">
											<PARA>
												<TAB tab-count="1"/>b.<TAB tab-count="1"/>The department of education shall, for each school food service establishment in a school of the city school district, post on its website no fewer than three years of inspection results from the department of health and mental hygiene beginning with any inspection after September 1, 2017. Such inspection results shall show such school food service establishment&apos;s degree of compliance with the provisions of the New York city health code, the state sanitary code and other applicable laws that require such establishments to operate in a sanitary manner so as to protect public health.</PARA>
										</RECORD>
										<RECORD id="0-0-0-42795" number="54648" version="1762">
											<PARA>
												<TAB tab-count="1"/>c.<TAB tab-count="1"/>The department of health and mental hygiene shall, for each school food service establishment for which inspection results are not posted pursuant to subdivision b, post on its website no fewer than three years of inspection results beginning with any inspection after September 1, 2017. Such inspection results shall show such school food service establishment&apos;s degree of compliance with the provisions of the New York city health code, the state sanitary code and other applicable laws that require such establishments to operate in a sanitary manner so as to protect public health.</PARA>
										</RECORD>
										<RECORD id="0-0-0-42796" number="54649" version="3">
											<PARA>(L.L. 2017/112, 7/16/2017, eff. 1/12/2018) <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-015]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
								<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-703" level-depth="9" toc-section="true">
									<RECORD id="0-0-0-42797" number="54650" version="3">
										<HEADING>§ 23-702 School cafeteria and kitchen inspection data.*</HEADING>
										<PARA>
											<DESTINATION id="0-0-0-10253" name="23-702(2)"/>§ 23-702 School cafeteria and kitchen inspection data.*</PARA>
									</RECORD>
									<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
										<RECORD id="0-0-0-42798" number="54651" version="3">
											<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-18">* <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Editor&apos;s note:</CHARFORMAT> there are two sections designated as § 23-702. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42799" number="54652" version="3">
											<PARA>
												<TAB tab-count="1"/>a.<TAB tab-count="1"/>Whenever any cafeteria or kitchen in a school of the city school district is inspected by the department of health and mental hygiene, the city school district shall post the following information on its website: <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42800" number="54653" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>1.<TAB tab-count="1"/>the date of the inspection or reinspection; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42801" number="54654" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>2.<TAB tab-count="1"/>the name and address of the school where the inspected cafeteria or kitchen is located; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42802" number="54655" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>3.<TAB tab-count="1"/>the facts established observed violations, if any, during such inspection and the severity level of such violations; <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42803" number="54656" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>4.<TAB tab-count="1"/>citations to the laws, regulations or rules for any violations observed during such inspection; and <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42804" number="54657" version="3">
											<PARA>
												<TAB tab-count="1"/>
												<TAB tab-count="1"/>5.<TAB tab-count="1"/>any corrective actions taken in response to such inspection. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42805" number="54658" version="3">
											<PARA>
												<TAB tab-count="1"/>b.<TAB tab-count="1"/>Inspection results posted on the website for the city department of education pursuant to this section shall be searchable by the school name and address. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42806" number="54659" version="3">
											<PARA>
												<TAB tab-count="1"/>c.<TAB tab-count="1"/>At least once every school year, the principal of every school of the city school district where students use a cafeteria or kitchen shall inform the parent or legal guardian of each student of such school that the information required by this section is available on the website of the city department of education. The principal shall inform such parent or legal guardian that such information is available in a manner consistent with how other information is communicated to such parent or legal guardian, including, but not limited to, email, mail, parent newsletter or notice to students to show their parent or legal guardian. <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
										<RECORD id="0-0-0-42807" number="54660" version="3">
											<PARA>(2017 N.Y. Laws Ch. 313, 9/13/2017, eff. 12/12/2017) <HIGHLIGHTER style="ALP" style-name-escaped="ALP" name="ALP" id="0-0-0-25">[ALP S-017]</HIGHLIGHTER>
											</PARA>
										</RECORD>
									</LEVEL>
								</LEVEL>
							</LEVEL>
						</LEVEL>
					</LEVEL>
				</LEVEL>
			</LEVEL>
		</LEVEL>
	</LEVEL>
</DOCUMENT>