<DOCUMENT source-infobase-name="Charter" content-collection-id="NYCcharter" source-infobase-title="New York City Charter" base-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCcharter\output\XIIBFNTGOGPHNCEJ\" default-split-level="Chapter" makefile-filename="D:\process\NFOProcess\codes\ny\newyorkcity\NYCcharter\output\XIIBFNTGOGPHNCEJ\NYCcharter.mak" css-stylesheet-href="#!-- #ID=NYCcharter_css_id --#" xml-output-dir="D:\process\NFOProcess\codes\ny\newyorkcity\NYCcharter\output\XIIBFNTGOGPHNCEJ\XML\" css-stylesheet-name="NYCcharter_css" makefile-document-depth="2">
	<LEVEL style-name="Chapter" style-name-escaped="Chapter" style-id="0-0-0-35" level-depth="2" toc-section="false">
		<RECORD id="0-0-0-5370" number="3229" version="320">
			<HEADING>Chapter 24: Department of Social Services</HEADING>
			<PARA>
				<DESTINATION id="0-0-0-791" name="Chapter 24"/>Chapter 24: Department of Social Services</PARA>
		</RECORD>
		<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-38" level-depth="3" toc-section="true">
			<RECORD id="0-0-0-2140" number="3230" version="3">
				<HEADING>Section 601. Department; commissioner. </HEADING>
				<PARA>
					<DESTINATION id="0-0-0-793" name="601"/>Section 601. <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Department; commissioner. </CHARFORMAT>
				</PARA>
			</RECORD>
			<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
				<RECORD id="0-0-0-2141" number="3231" version="617">
					<PARA>There shall be a department of social services the head of which shall be the commissioner of social services. </PARA>
				</RECORD>
			</LEVEL>
		</LEVEL>
		<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-38" level-depth="3" toc-section="true">
			<RECORD id="0-0-0-2142" number="3232" version="3">
				<HEADING>Section 602. Deputies. </HEADING>
				<PARA>
					<DESTINATION id="0-0-0-795" name="602"/>Section 602. <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Deputies. </CHARFORMAT>
				</PARA>
			</RECORD>
			<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
				<RECORD id="0-0-0-2143" number="3233" version="617">
					<PARA>The commissioner may appoint three deputies. </PARA>
				</RECORD>
			</LEVEL>
		</LEVEL>
		<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-38" level-depth="3" toc-section="true">
			<RECORD id="0-0-0-2144" number="3234" version="3">
				<HEADING>Section 603. Powers and duties. </HEADING>
				<PARA>
					<DESTINATION id="0-0-0-797" name="603"/>Section 603. <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Powers and duties. </CHARFORMAT>
				</PARA>
			</RECORD>
			<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
				<RECORD id="0-0-0-2145" number="3235" version="617">
					<PARA>Except as otherwise provided in <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-21" type="Jump" destination-name="Chapter 24-a" destination-id="0-0-0-803">chapters 24-A</LINK> and <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-21" type="Jump" destination-name="Chapter 24-b" destination-id="0-0-0-815">24-B</LINK>, the commissioner shall have the powers and perform the duties of a commissioner of social services under the social services law, provided that no form of outdoor relief shall be dispensed by the city except under the provisions of a state or local law which shall specifically provide the method, manner and conditions of dispensing the same. </PARA>
				</RECORD>
				<RECORD id="0-0-0-2146" number="3236" version="731">
					<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-19">
						<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Editor&apos;s note:</CHARFORMAT> For related unconsolidated provisions, see Administrative Code Appendix A at <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-21" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="L.L. 1993/051" destination-id="0-0-0-0">L.L. 1993/051</LINK>. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-24">[ALP S-085]</HIGHLIGHTER>
					</PARA>
				</RECORD>
			</LEVEL>
		</LEVEL>
		<LEVEL style-name="Section" style-name-escaped="Section" style-id="0-0-0-38" level-depth="3" toc-section="true">
			<RECORD id="0-0-0-6810" number="3237" version="731">
				<HEADING>Section 604. Public institutions under the commissioner. </HEADING>
				<PARA>
					<DESTINATION id="0-0-0-799" name="604"/>Section 604. <CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Public institutions under the commissioner. </CHARFORMAT>
				</PARA>
			</RECORD>
			<LEVEL style-name="Normal Level" style-name-escaped="Normal-Level" style-id="0-0-0-0" level-depth="0" toc-section="false">
				<RECORD id="0-0-0-2147" number="3238" version="617">
					<PARA>The commissioner shall control, maintain and operate such institutions as are now or may be put under his or her control. </PARA>
				</RECORD>
				<RECORD id="0-0-0-2148" number="3239" version="685">
					<PARA style-name="EdNoteSm" style-name-escaped="EdNoteSm" style-id="0-0-0-19">
						<CHARFORMAT bold="1" italic="0" underline="0" strike-out="0" hidden="0">Editor&apos;s note:</CHARFORMAT> For related unconsolidated provisions, see Administrative Code Appendix A at <LINK style-name="Jump" style-name-escaped="Jump" style-id="0-0-0-21" type="Inter Infobase Jump" destination-infobase-id="671734137-329684122-0-0" destination-infobase-uil="L:\NY\New York City\Folio\Working\Admin.nfo" destination-infobase-name="" destination-infobase-title="" destination-name="L.L. 2003/052" destination-id="0-0-0-0">L.L. 2003/052</LINK>. <HIGHLIGHTER style="highlighter-ALP" original-style-name="ALP" style-name-escaped="highlighter-ALP" name="ALP" id="0-0-0-24">[ALP S-084]</HIGHLIGHTER>
					</PARA>
				</RECORD>
			</LEVEL>
		</LEVEL>
